<div dir="ltr" id="threeD3"></div>

<style>
    #threeD3 {
        width: 100%;
        aspect-ratio: 16 / 9;
        display: block;
        min-height: 200px;
        background: #000000;
    }

    @media (max-width: 768px) {
        #threeD3 {
            aspect-ratio: 4 / 3;
        }
    }

    #controls3 {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 10px 14px;
        background: #1a1a1a;
        border-radius: 8px;
        margin-top: 10px;
    }

    .slice-row3 {
        display: flex;
        align-items: center;
        gap: 10px;
        flex: 1;
    }

    .slice-toggle3 {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: 1.5px solid;
        background: transparent;
        cursor: pointer;
        font-size: 14px;
        font-weight: bold;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background 0.15s;
    }

    .slice-toggle3.x-toggle3 {
        border-color: #4488ff;
        color: #4488ff;
    }
    .slice-toggle3.x-toggle3.active {
        background: #4488ff22;
    }
    .slice-toggle3.y-toggle3 {
        border-color: #ff4444;
        color: #ff4444;
    }
    .slice-toggle3.y-toggle3.active {
        background: #ff444422;
    }

    .slice-label3 {
        font-size: 13px;
        font-style: italic;
        font-family: serif;
        white-space: nowrap;
        width: 16px;
        text-align: center;
    }

    .slice-label3.x-label3 {
        color: #4488ff;
    }
    .slice-label3.y-label3 {
        color: #ff4444;
    }

    .slider-wrap3 {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    .slider-wrap3 input[type="range"] {
        width: 100%;
    }

    .num-input3 {
        width: 60px;
        font-size: 13px;
        font-family: monospace;
        background: #222;
        color: #eee;
        border: 1px solid #444;
        border-radius: 6px;
        padding: 4px 6px;
        text-align: center;
    }

    .num-input3:focus {
        outline: none;
    }
    #xNumInput3:focus {
        border-color: #4488ff;
    }
    #yNumInput3:focus {
        border-color: #ff4444;
    }

    #eqBox3 {
        color: #eee;
        background: #222;
        border: 1px solid #333;
        border-radius: 6px;
        padding: 8px 14px;
        overflow-x: auto;
        margin-top: 6px;
        text-align: center;
        min-height: 40px;
    }

    #hint3 {
        font-size: 12px;
        color: #666;
        padding: 6px 2px;
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }
</style>

<div id="controls3">
    <div class="slice-row3">
        <button class="slice-toggle3 x-toggle3 active" id="xToggle3">x</button>
        <span class="slice-label3 x-label3">x</span>
        <div class="slider-wrap3">
            <input
                type="range"
                id="xSlider3"
                min="-200"
                max="200"
                value="0"
                step="1"
                list="xTicks3"
            />
            <datalist id="xTicks3">
                <option value="-200" label="-4"></option>
                <option value="-100" label="-2"></option>
                <option value="0" label="0"></option>
                <option value="100" label="2"></option>
                <option value="200" label="4"></option>
            </datalist>
        </div>
        <input
            type="number"
            id="xNumInput3"
            class="num-input3"
            value="0"
            min="-4"
            max="4"
            step="0.01"
        />
    </div>
    <div class="slice-row3">
        <button class="slice-toggle3 y-toggle3 active" id="yToggle3">y</button>
        <span class="slice-label3 y-label3">y</span>
        <div class="slider-wrap3">
            <input
                type="range"
                id="ySlider3"
                min="-200"
                max="200"
                value="50"
                step="1"
                list="yTicks3"
            />
            <datalist id="yTicks3">
                <option value="-200" label="-4"></option>
                <option value="-100" label="-2"></option>
                <option value="0" label="0"></option>
                <option value="100" label="2"></option>
                <option value="200" label="4"></option>
            </datalist>
        </div>
        <input
            type="number"
            id="yNumInput3"
            class="num-input3"
            value="1"
            min="-4"
            max="4"
            step="0.01"
        />
    </div>
</div>
<div id="eqBox3"></div>

<script>
    import * as THREE from "three";
    import { OrbitControls } from "three/addons/controls/OrbitControls.js";
    import katex from "katex";

    const container = document.getElementById("threeD3")!;
    const xSlider = document.getElementById("xSlider3") as HTMLInputElement;
    const ySlider = document.getElementById("ySlider3") as HTMLInputElement;
    const xNumInput = document.getElementById("xNumInput3") as HTMLInputElement;
    const yNumInput = document.getElementById("yNumInput3") as HTMLInputElement;
    const xToggle = document.getElementById("xToggle3") as HTMLButtonElement;
    const yToggle = document.getElementById("yToggle3") as HTMLButtonElement;
    const eqBox = document.getElementById("eqBox3")!;

    const initScene = () => {
        const width = container.clientWidth;
        const height = container.clientHeight;
        if (width === 0 || height === 0) {
            requestAnimationFrame(initScene);
            return;
        }

        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(width, height);
        renderer.setPixelRatio(window.devicePixelRatio);
        renderer.setClearColor(0x000000, 1);
        container.appendChild(renderer.domElement);

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(
            40,
            width / height,
            0.1,
            100,
        );
        camera.position.set(0, 6, 12);
        camera.lookAt(0, 2, 0);

        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.dampingFactor = 0.05;
        controls.target.set(0, 2, 0);
        controls.minDistance = 4;
        controls.maxDistance = 20;

        const getVal = (x: number, _y: number) => x + 5;

        const softenVal = (v: number) => {
            const MAX = 10;
            return MAX * (1 - Math.exp(-Math.abs(v) / MAX)) * Math.sign(v);
        };

        const valToColor = (v: number): THREE.Color => {
            const t = Math.min(Math.max((v - 1) / 8, 0), 1);
            const color = new THREE.Color();
            color.setHSL(0.66 * (1 - t), 1.0, 0.5);
            return color;
        };

        const STEPS = 120;
        const RANGE = 4.0;
        const RANGE_MAX = 200;

        const geometry = new THREE.BufferGeometry();
        const positions: number[] = [];
        const colors: number[] = [];
        const indices: number[] = [];

        for (let i = 0; i <= STEPS; i++) {
            for (let j = 0; j <= STEPS; j++) {
                const x = -RANGE + (i / STEPS) * RANGE * 2;
                const y = -RANGE + (j / STEPS) * RANGE * 2;
                const v = softenVal(getVal(x, y));
                const color = valToColor(v);
                positions.push(x, v, -y);
                colors.push(color.r, color.g, color.b);
            }
        }

        for (let i = 0; i < STEPS; i++) {
            for (let j = 0; j < STEPS; j++) {
                const a = i * (STEPS + 1) + j;
                const b = a + 1;
                const c = a + (STEPS + 1);
                const d = c + 1;
                indices.push(a, c, b);
                indices.push(b, c, d);
            }
        }

        geometry.setIndex(indices);
        geometry.setAttribute(
            "position",
            new THREE.Float32BufferAttribute(positions, 3),
        );
        geometry.setAttribute(
            "color",
            new THREE.Float32BufferAttribute(colors, 3),
        );
        geometry.computeVertexNormals();

        scene.add(
            new THREE.Mesh(
                geometry,
                new THREE.MeshPhongMaterial({
                    vertexColors: true,
                    side: THREE.DoubleSide,
                    shininess: 60,
                    specular: new THREE.Color(0x333333),
                    transparent: true,
                    opacity: 0.85,
                }),
            ),
        );

        const axisMat = (color: number) =>
            new THREE.MeshBasicMaterial({
                color,
                depthTest: false,
                depthWrite: false,
            });

        const makeArrow = (
            dir: THREE.Vector3,
            origin: THREE.Vector3,
            length: number,
            color: number,
        ) => {
            const d = dir.clone().normalize();
            const end = origin.clone().addScaledVector(d, length);
            const shaftEnd = origin.clone().addScaledVector(d, length - 0.4);
            const mat = axisMat(color);
            const tube = new THREE.Mesh(
                new THREE.TubeGeometry(
                    new THREE.LineCurve3(origin, shaftEnd),
                    1,
                    0.04,
                    8,
                    false,
                ),
                mat,
            );
            tube.renderOrder = 999;
            scene.add(tube);
            const cap = new THREE.Mesh(new THREE.CircleGeometry(0.04, 8), mat);
            cap.position.copy(origin);
            cap.quaternion.setFromUnitVectors(
                new THREE.Vector3(0, 0, 1),
                d.clone().negate(),
            );
            cap.renderOrder = 999;
            scene.add(cap);
            const cone = new THREE.Mesh(
                new THREE.ConeGeometry(0.1, 0.4, 16),
                mat,
            );
            cone.position.copy(end.clone().addScaledVector(d, -0.2));
            cone.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), d);
            cone.renderOrder = 999;
            scene.add(cone);
        };

        makeArrow(
            new THREE.Vector3(1, 0, 0),
            new THREE.Vector3(-3.5, 0, 0),
            8.0,
            0x4488ff,
        );
        makeArrow(
            new THREE.Vector3(0, 0, -1),
            new THREE.Vector3(0, 0, 3.5),
            8.0,
            0xff4444,
        );
        makeArrow(
            new THREE.Vector3(0, 1, 0),
            new THREE.Vector3(0, 0, 0),
            10.0,
            0x44cc88,
        );

        scene.add(new THREE.GridHelper(10, 10, 0x333333, 0x222222));

        const makeLabel = (
            lines: { text: string; font: string; color: string; y: number }[],
            position: THREE.Vector3,
            scaleX: number = 1.6,
            scaleY: number = 0.4,
        ) => {
            const canvas = document.createElement("canvas");
            canvas.width = 512;
            canvas.height = 128;
            const ctx = canvas.getContext("2d")!;
            ctx.clearRect(0, 0, 512, 128);
            for (const line of lines) {
                ctx.font = line.font;
                ctx.fillStyle = line.color;
                ctx.textAlign = "center";
                ctx.textBaseline = "middle";
                ctx.fillText(line.text, 256, line.y);
            }
            const sprite = new THREE.Sprite(
                new THREE.SpriteMaterial({
                    map: new THREE.CanvasTexture(canvas),
                    transparent: true,
                }),
            );
            sprite.position.copy(position);
            sprite.scale.set(scaleX, scaleY, 1);
            scene.add(sprite);
            return sprite;
        };

        makeLabel(
            [
                {
                    text: "x",
                    font: "italic bold 64px serif",
                    color: "#4488ff",
                    y: 48,
                },
                {
                    text: "حقيقي (Real)",
                    font: "bold 32px sans-serif",
                    color: "#3366cc",
                    y: 96,
                },
            ],
            new THREE.Vector3(3.6, 0.5, 0),
            2.0,
            0.6,
        );
        makeLabel(
            [
                {
                    text: "y",
                    font: "italic bold 64px serif",
                    color: "#ff4444",
                    y: 48,
                },
                {
                    text: "تخيلي (Imaginary)",
                    font: "bold 28px sans-serif",
                    color: "#cc3333",
                    y: 96,
                },
            ],
            new THREE.Vector3(0.3, 0.5, -3.9),
            2.4,
            0.6,
        );
        makeLabel(
            [
                {
                    text: "f(x + iy) = x + 5",
                    font: "italic bold 60px serif",
                    color: "#44cc88",
                    y: 64,
                },
            ],
            new THREE.Vector3(-1.5, 8.5, 0),
            3.2,
            0.45,
        );

        const makeDynamicLabel = (
            text: string,
            color: string,
            position: THREE.Vector3,
            scaleX: number,
            scaleY: number,
        ) => {
            const canvas = document.createElement("canvas");
            canvas.width = 256;
            canvas.height = 64;
            const ctx = canvas.getContext("2d")!;
            const draw = (t: string) => {
                ctx.clearRect(0, 0, 256, 64);
                ctx.font = "bold 36px monospace";
                ctx.fillStyle = color;
                ctx.textAlign = "center";
                ctx.textBaseline = "middle";
                ctx.fillText(t, 128, 32);
            };
            draw(text);
            const tex = new THREE.CanvasTexture(canvas);
            const sprite = new THREE.Sprite(
                new THREE.SpriteMaterial({
                    map: tex,
                    transparent: true,
                    depthTest: false,
                }),
            );
            sprite.renderOrder = 1001;
            sprite.position.copy(position);
            sprite.scale.set(scaleX, scaleY, 1);
            scene.add(sprite);
            return {
                sprite,
                update: (t: string, pos: THREE.Vector3) => {
                    draw(t);
                    tex.needsUpdate = true;
                    sprite.position.copy(pos);
                },
            };
        };

        const makeDashedLine = (color: number) => {
            const mat = new THREE.LineDashedMaterial({
                color,
                dashSize: 0.15,
                gapSize: 0.1,
                depthTest: false,
            });
            const geo = new THREE.BufferGeometry().setFromPoints([
                new THREE.Vector3(0, 0, 0),
                new THREE.Vector3(0, -1, 0),
            ]);
            const line = new THREE.Line(geo, mat);
            line.computeLineDistances();
            line.renderOrder = 998;
            scene.add(line);
            return {
                line,
                update: (from: THREE.Vector3, to: THREE.Vector3) => {
                    const pts = [from, to];
                    line.geometry.setFromPoints(pts);
                    line.computeLineDistances();
                    line.geometry.attributes.position.needsUpdate = true;
                },
            };
        };

        let sliceX = 0,
            sliceY = 1;
        let xActive = true,
            yActive = true;
        let xCurve: THREE.Line | null = null;
        let yCurve: THREE.Line | null = null;
        let intersectDot: THREE.Mesh | null = null;

        const dropLineX = makeDashedLine(0x4488ff);
        const dropLineY = makeDashedLine(0xff4444);
        const pathLine = makeDashedLine(0x888888);

        const fmt = (n: number) => {
            const r = Math.round(n * 100) / 100;
            return Number.isInteger(r)
                ? String(r)
                : r.toFixed(2).replace(/\.?0+$/, "");
        };

        const xLabel = makeDynamicLabel(
            "x=0",
            "#4488ff",
            new THREE.Vector3(0, 0, 0),
            1.2,
            0.3,
        );
        const yLabel = makeDynamicLabel(
            "y=1",
            "#ff4444",
            new THREE.Vector3(0, 0, 0),
            1.2,
            0.3,
        );

        const SS = 200;

        const buildXSlice = (x0: number) => {
            if (xCurve) scene.remove(xCurve);
            if (!xActive) {
                xCurve = null;
                return;
            }
            const pts: THREE.Vector3[] = [];
            for (let i = 0; i <= SS; i++) {
                const y = -RANGE + (i / SS) * RANGE * 2;
                const v = softenVal(getVal(x0, y));
                pts.push(new THREE.Vector3(x0, v, -y));
            }
            xCurve = new THREE.Line(
                new THREE.BufferGeometry().setFromPoints(pts),
                new THREE.LineBasicMaterial({ color: 0x4488ff, linewidth: 2 }),
            );
            scene.add(xCurve);
        };

        const buildYSlice = (y0: number) => {
            if (yCurve) scene.remove(yCurve);
            if (!yActive) {
                yCurve = null;
                return;
            }
            const pts: THREE.Vector3[] = [];
            for (let i = 0; i <= SS; i++) {
                const x = -RANGE + (i / SS) * RANGE * 2;
                const v = softenVal(getVal(x, y0));
                pts.push(new THREE.Vector3(x, v, -y0));
            }
            yCurve = new THREE.Line(
                new THREE.BufferGeometry().setFromPoints(pts),
                new THREE.LineBasicMaterial({ color: 0xff4444, linewidth: 2 }),
            );
            scene.add(yCurve);
        };

        const buildIntersect = () => {
            if (intersectDot) scene.remove(intersectDot);

            const offPos = new THREE.Vector3(0, -999, 0);
            if (!xActive || !yActive) {
                intersectDot = null;
                dropLineX.update(offPos, offPos);
                dropLineY.update(offPos, offPos);
                pathLine.update(offPos, offPos);
                xLabel.update("", offPos);
                yLabel.update("", offPos);
                return;
            }

            const v = softenVal(getVal(sliceX, sliceY));
            const floorPos = new THREE.Vector3(sliceX, 0, -sliceY);
            const xAnchor = new THREE.Vector3(sliceX, 0, 0);
            const yAnchor = new THREE.Vector3(0, 0, -sliceY);
            const dotPos = new THREE.Vector3(sliceX, v, -sliceY);

            intersectDot = new THREE.Mesh(
                new THREE.SphereGeometry(0.12, 16, 16),
                new THREE.MeshBasicMaterial({
                    color: 0x44cc88,
                    depthTest: false,
                }),
            );
            intersectDot.position.copy(dotPos);
            intersectDot.renderOrder = 1000;
            scene.add(intersectDot);

            dropLineX.update(new THREE.Vector3(0, 0, 0), xAnchor);
            dropLineY.update(new THREE.Vector3(0, 0, 0), yAnchor);
            pathLine.update(floorPos, dotPos);
            dropLineX.update(yAnchor, floorPos);
            dropLineY.update(xAnchor, floorPos);

            const xMid = new THREE.Vector3(sliceX / 2, 0.2, -sliceY);
            const yMid = new THREE.Vector3(sliceX, 0.2, -sliceY / 2);
            xLabel.update(`x = ${fmt(sliceX)}`, xMid);
            yLabel.update(`y = ${fmt(sliceY)}`, yMid);
        };

        const updateEquation = () => {
            const xCol = `\\textcolor{#4488ff}{${fmt(sliceX)}}`;
            const yCol = `\\textcolor{#ff4444}{${fmt(Math.abs(sliceY))}i}`;
            const ySign = sliceY >= 0 ? "+" : "-";
            const val = Math.round((sliceX + 5) * 100) / 100;

            const steps: string[] = [String.raw`f(x + iy) = x + 5`];

            if (xActive && yActive) {
                steps.push(
                    String.raw`f(${xCol} ${ySign} ${yCol}) = ${xCol} + 5`,
                );
                steps.push(String.raw`= \textcolor{#44cc88}{${fmt(val)}}`);
            } else if (xActive && !yActive) {
                steps.push(String.raw`f(${xCol} + iy) = ${xCol} + 5`);
                steps.push(String.raw`= \textcolor{#44cc88}{${fmt(val)}}`);
            } else if (!xActive && yActive) {
                steps.push(String.raw`f(x + ${ySign} ${yCol}) = x + 5`);
            }

            eqBox.innerHTML = "";
            for (const step of steps) {
                const line = document.createElement("div");
                katex.render(step, line, {
                    throwOnError: false,
                    displayMode: false,
                });
                eqBox.appendChild(line);
            }
        };

        const rebuild = () => {
            buildXSlice(sliceX);
            buildYSlice(sliceY);
            buildIntersect();
            updateEquation();
        };

        const setX = (v: number) => {
            sliceX = Math.max(-RANGE, Math.min(RANGE, v));
            xSlider.value = String(Math.round((sliceX / RANGE) * RANGE_MAX));
            xNumInput.value = sliceX.toFixed(2);
            rebuild();
        };

        const setY = (v: number) => {
            sliceY = Math.max(-RANGE, Math.min(RANGE, v));
            ySlider.value = String(Math.round((sliceY / RANGE) * RANGE_MAX));
            yNumInput.value = sliceY.toFixed(2);
            rebuild();
        };

        xToggle.addEventListener("click", () => {
            xActive = !xActive;
            xToggle.classList.toggle("active", xActive);
            rebuild();
        });
        yToggle.addEventListener("click", () => {
            yActive = !yActive;
            yToggle.classList.toggle("active", yActive);
            rebuild();
        });

        xSlider.addEventListener("input", () =>
            setX((parseInt(xSlider.value) / RANGE_MAX) * RANGE),
        );
        ySlider.addEventListener("input", () =>
            setY((parseInt(ySlider.value) / RANGE_MAX) * RANGE),
        );

        xNumInput.addEventListener("input", () => {
            const v = parseFloat(xNumInput.value);
            if (!isNaN(v)) setX(v);
        });
        yNumInput.addEventListener("input", () => {
            const v = parseFloat(yNumInput.value);
            if (!isNaN(v)) setY(v);
        });
        xNumInput.addEventListener("keydown", (e) => {
            if (e.key === "ArrowUp") {
                e.preventDefault();
                setX(sliceX + 0.1);
            }
            if (e.key === "ArrowDown") {
                e.preventDefault();
                setX(sliceX - 0.1);
            }
        });
        yNumInput.addEventListener("keydown", (e) => {
            if (e.key === "ArrowUp") {
                e.preventDefault();
                setY(sliceY + 0.1);
            }
            if (e.key === "ArrowDown") {
                e.preventDefault();
                setY(sliceY - 0.1);
            }
        });

        rebuild();

        scene.add(new THREE.AmbientLight(0xffffff, 0.4));
        const keyLight = new THREE.DirectionalLight(0xffffff, 1.2);
        keyLight.position.set(-3, 6, 4);
        scene.add(keyLight);
        const fillLight = new THREE.DirectionalLight(0xffffff, 0.4);
        fillLight.position.set(4, 2, -3);
        scene.add(fillLight);

        new ResizeObserver((entries) => {
            for (const entry of entries) {
                const { width, height } = entry.contentRect;
                renderer.setSize(width, height);
                camera.aspect = width / height;
                camera.updateProjectionMatrix();
            }
        }).observe(container);

        const animate = () => {
            requestAnimationFrame(animate);
            controls.update();
            renderer.render(scene, camera);
        };
        animate();
    };

    initScene();
</script>
