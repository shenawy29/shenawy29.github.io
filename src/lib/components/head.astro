---
import { SEO } from "astro-seo";
const { title, type, site, description, ogImage } = Astro.props;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link
    rel="preload"
    href="/fonts/Cairo.woff2"
    as="font"
    type="font/woff2"
    crossorigin
/>
<link
    rel="preload"
    href="/fonts/FiraCode.woff2"
    as="font"
    type="font/woff2"
    crossorigin
/>
<SEO
    title={title}
    description={description}
    canonical={site + Astro.url.pathname}
    openGraph={{
        basic: {
            title: title,
            type: type ?? "website",
            image: site + (ogImage ?? "/og/default.png"),
            url: site + Astro.url.pathname,
        },
        optional: {
            description: description,
            siteName: "شناوي",
            locale: "ar_EG",
        },
    }}
    twitter={{
        card: "summary_large_image",
        title: title,
        description: description,
        image: site + (ogImage ?? "/og/default.png"),
    }}
/>
