---
import { SEO } from "astro-seo";
const { title, type, site, description, ogImage } = Astro.props;
import { Font } from "astro:assets";
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<Font cssVariable="--font-vazirmatn" preload />
<Font cssVariable="--font-rokkitt" preload />
<Font cssVariable="--font-fira" preload />
<Font cssVariable="--font-cairo" preload />

<link rel="sitemap" href="/sitemap-index.xml" />

<SEO
    title={title}
    description={description}
    canonical={site + Astro.url.pathname}
    openGraph={{
        basic: {
            title: title,
            type: type ?? "website",
            image: site + (ogImage ?? "/og/default.png"),
            url: site + Astro.url.pathname,
        },
        optional: {
            description: description,
            siteName: "شناوي",
            locale: "ar_EG",
        },
    }}
    twitter={{
        card: "summary_large_image",
        title: title,
        description: description,
        image: site + (ogImage ?? "/og/default.png"),
    }}
/>
