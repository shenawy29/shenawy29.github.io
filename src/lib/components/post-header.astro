---
let { post } = Astro.props;
---

<div class="h-min w-full">
    <div
        class="flex flex-wrap gap-x-3 divide-dotted font-mono text-xl text-wrap opacity-60"
    >
        <span class="mb-1 text-wrap">
            {post.data.pubDate.toISOString().substring(0, 10)}
        </span>
        {
            post.data.tags.map((t) => (
                <>
                    <span> • </span>
                    <a href={`/tags#${t}`}>
                        <span>{t}#</span>
                    </a>
                </>
            ))
        }
    </div>
    <h1>
        <a
            href={`/${post.data.pubDate.toISOString().substring(0, 10)}/${post.id}`}
        >
            {post.data.title}
        </a>
    </h1>
</div>
